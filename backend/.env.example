# LLM 配置 —— 复制本文件为 .env 并填入真实值
# provider 决定使用哪种 API 格式: openai | anthropic
# DeepSeek / 硅基流动 / OpenAI 都用 openai 兼容格式

# ---- 预设 A: DeepSeek(主, 便宜好用) ----
LLM_PROVIDER=openai
LLM_API_KEY=sk-your-deepseek-key
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# ---- 预设 B: 硅基流动(备用, DeepSeek 额度用完时切换) ----
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-your-siliconflow-key
# LLM_BASE_URL=https://api.siliconflow.cn/v1
# LLM_MODEL=deepseek-ai/DeepSeek-V3

# ---- 预设 C: Anthropic Claude(长文档/复杂申请书一致性更好) ----
# LLM_PROVIDER=anthropic
# LLM_API_KEY=sk-ant-xxx
# LLM_BASE_URL=https://api.anthropic.com
# LLM_MODEL=claude-sonnet-4-6

# 开发期省钱开关: true 时不调用真实模型, 返回假数据(用于 UI 开发和自动化测试)
MOCK_LLM=false

# sidecar 监听地址与端口
# HOST 默认 127.0.0.1, 仅本机可访问(最安全)。
# 若要让同一局域网的其他电脑/手机也能用, 设为 0.0.0.0 (或用 scripts/serve-lan.ps1)。
#   注意: 设为 0.0.0.0 后, 局域网内任何人都能用本机, 也会消耗你的模型额度, 请仅在可信网络使用。
HOST=127.0.0.1
PORT=8766

# 自动降级备用供应商: 主供应商余额不足/配额超限时自动切换(留空则不启用)
FALLBACK_PROVIDER=openai
FALLBACK_API_KEY=
FALLBACK_BASE_URL=https://api.siliconflow.cn/v1
FALLBACK_MODEL=deepseek-ai/DeepSeek-V3

# 可选: 提供给 PubMed(NCBI) 的联系邮箱, 检索更稳定(立项依据功能用到)
NCBI_EMAIL=
# 可选: NCBI API key, 填写后检索限速从 3 次/秒提升到 10 次/秒, 减少 429 失败。
# 申请: https://www.ncbi.nlm.nih.gov/account/ -> Settings -> API Key Management
NCBI_API_KEY=
